{
  "name": "frgmt-xyz",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite --host 0.0.0.0",
    "build": "bunx --bun vite build",
    "preview": "bunx --bun vite preview --host 0.0.0.0",
    "check": "bunx --bun tsc --noEmit && bunx --bun tsc --noEmit -p worker/tsconfig.json",
    "cms:migrate": "wrangler d1 execute kona-blog-db --remote --file=migrations/0001_cms.sql",
    "cms:migrate:local": "wrangler d1 execute kona-blog-db --local --file=migrations/0001_cms.sql",
    "cms:create-admin": "node scripts/create-admin.mjs",
    "cms:dev": "wrangler dev",
    "deploy": "bunx --bun vite build && wrangler deploy"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "typescript": "latest",
    "react": "latest",
    "react-dom": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "wrangler": "latest"
  }
}
